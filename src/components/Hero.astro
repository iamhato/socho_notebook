---

<section class="hero">
    <div class="hero-content">
        <img src="/image/header-logo.png" />
    </div>
</section>

<style>
    .hero-content {
        height: 100vh; /* 画面ぴったり */
        max-height: 1000px;
        display: flex;
        justify-content: center;
        align-items: center;
        background-image: url("/image/mv.webp");
        background-size: cover;
        background-position: center;
        text-align: center;
    }
    .hero-content img {
        animation: cloudBounceIn 3s cubic-bezier(0.68, -0.55, 0.27, 1.55) 0s
            forwards;
        opacity: 0;
        transform: translateY(-20px) scale(0.9);
        filter: blur(5px); /* 最初は少しぼかしておく（雲っぽさ） */
    }

    @keyframes cloudBounceIn {
        0% {
            opacity: 0;
            transform: translateY(-20px) scale(0.9);
            filter: blur(5px);
        }
        50% {
            opacity: 1;
            transform: translateY(5px) scale(1.02);
            filter: blur(0);
        }
        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
            filter: blur(0);
        }
    }

    @media screen and (max-width: 1200px) {
        .hero-content {
            background-image: url("/image/mv-sp.webp");
        }
        .hero-content img {
            width: 80% !important;
        }
    }

    .hero-content img {
        width: 33%;
    }

    h1 {
        font-size: 10vw; 
        font-weight: 900;
        line-height: 1;
        margin: 0;
        letter-spacing: -0.05em;
    }

    p {
        font-size: 1.5rem;
        font-weight: 400;
        color: #999;
        margin-top: 1rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
    }
</style>
