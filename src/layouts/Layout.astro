---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="京都市左京区に生息しているマスロックプロジェクト 早朝ノートブック！のオフィシャルサイト" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap"
			rel="stylesheet"
		/>
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://socho-notebook.pages.dev/" />
		<meta property="og:title" content="早朝ノートブック！| Official Website" />
		<meta property="og:description" content="京都市左京区に生息しているマスロックプロジェクト 早朝ノートブック！のオフィシャルサイト" />
		<meta property="og:image" content="/image/header-logo.png" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="早朝ノートブック！| Official Website" />
		<meta name="twitter:description" content="京都市左京区に生息しているマスロックプロジェクト 早朝ノートブック！のオフィシャルサイト" />
		<meta name="twitter:image" content="/image/header-logo.png" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #0037ff;
		--text-color: #ffffff;
		--accent-color: #ffffff; /* 控えめなアクセント */
		--font-main: "Inter", sans-serif;
	}

	html {
		font-family: var(--font-main);
		background: var(--bg-color);
		color: var(--text-color);
		scroll-behavior: smooth; /* スムーススクロール */
	}

	body {
		margin: 0;
		padding: 0;
		line-height: 1.6;
	}

	/* 共通のセクションタイトルスタイル（参考サイト意識） */
	section h2 {
		font-size: 3rem;
		font-weight: 900;
		text-transform: uppercase;
		letter-spacing: -0.05em;
		margin-bottom: 2rem;
		text-align: center;
		letter-spacing: 10px;
	}

	@media (max-width: 768px) {
		section h2 {
			font-size: 2rem;
		}
	}

	img {
		max-width: 100%;
		height: auto;
	}
</style>
